<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="9.0" ExtensionBundleId="com.lora-mask-loss.exporter" ExtensionBundleVersion="1.0.0">
  <ExtensionList>
    <Extension Id="com.lora-mask-loss.exporter.panel" Version="1.0.0" />
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="PHSP" Version="[19.0,99.9]" />
      <Host Name="PHXS" Version="[19.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.lora-mask-loss.exporter.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./client/jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--disable-features=SameSiteByDefaultCookies,CookiesWithoutSameSiteMustBeSecure</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>LoRA Mask Loss</Menu>
          <Geometry>
            <Size>
              <Width>480</Width>
              <Height>700</Height>
            </Size>
            <MinSize>
              <Width>280</Width>
              <Height>350</Height>
            </MinSize>
          </Geometry>
          <Icons>
            <Icon Type="Normal">./client/assets/icon-16.png</Icon>
            <Icon Type="Disabled">./client/assets/icon-16.png</Icon>
          </Icons>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
